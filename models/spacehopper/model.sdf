    </link>
    <joint name="solar_panel_joint" type="fixed">
      <parent>base_link</parent>
      <child>solar_panel</child>
    </joint>

    <!-- ══════════ REACTION WHEELS (inside chassis) ══════════ -->
    <link name="rw_x">
      <pose>0 0 0.25 0 1.5707963267948966 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.000140</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000140</iyy><iyz>0</iyz>
          <izz>0.000270</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.02</length></cylinder></geometry>

      <visual name="cell_grid_h3">
        <pose>0 -0.045 0.003 0 0 0</pose>
        <geometry><box><size>0.18 0.001 0.001</size></box></geometry>
        <material>
          <ambient>0.7 0.7 0.7 1</ambient>
          <diffuse>0.7 0.7 0.7 1</diffuse>

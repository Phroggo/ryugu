      <!-- ── Antenna ── -->

      <!-- UHF whip antenna: dark anodized mast, small flat-plate patch
           antenna instead of a glossy sphere tip (a bright white ball read
           as a toy topper - real whip antennas taper to a plain dark tip) -->

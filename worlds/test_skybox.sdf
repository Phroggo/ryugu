<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="test_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <scene>
      <ambient>0.3 0.3 0.3 1.0</ambient>
      <background>0 0 0 1.0</background>
    </scene>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- TEST 1: Simple red box, no PBR, no texture -->
    <model name="red_box">
      <static>true</static>
      <pose>0 0 3 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box><size>2 2 2</size></box>
          </geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
            <emissive>1 0 0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- TEST 2: Textured plane above using ABSOLUTE path in PBR -->
    <model name="textured_ceiling">
      <static>true</static>
      <pose>0 0 20 3.14159 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>40 40</size>
            </plane>
          </geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <emissive>0.5 0.5 0.5 1</emissive>
            <pbr>
              <metal>
                <albedo_map>/home/melvin/ryugu_v2_ws/src/ryugu_sim/models/skydome/materials/textures/space_skybox.jpg</albedo_map>
                <roughness>1.0</roughness>
                <metalness>0.0</metalness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>

    <!-- TEST 3: Green box, no PBR, solid color -->
    <model name="green_box">
      <static>true</static>
      <pose>5 0 3 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box><size>2 2 2</size></box>
          </geometry>
          <material>
            <ambient>0 1 0 1</ambient>
            <diffuse>0 1 0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>

<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="spacehopper">
    <!-- Ryugu's gravity (0.000114 m/s^2) produces velocities small enough that DART's
         default auto-sleep threshold puts the body to sleep mid-flight, permanently
         freezing it in the air. Must stay awake for micro-gravity hops to ever land. -->
    <allow_auto_disable>false</allow_auto_disable>

    <!-- ══════════ BASE CHASSIS ══════════ -->
    <link name="base_link">
      <pose>0 0 0.25 0 0 0</pose>
      <inertial>
        <mass>1.35</mass>
        <inertia>
          <ixx>0.009000</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.009000</iyy><iyz>0</iyz>
          <izz>0.009000</izz>
        </inertia>
      </inertial>

      <!-- Main hull (dark metallic) -->
      <visual name="hull_visual">
        <geometry><box><size>0.2 0.2 0.2</size></box></geometry>
        <material>
          <ambient>0.18 0.18 0.22 1</ambient>
          <diffuse>0.18 0.18 0.22 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>

      <!-- ── MLI thermal blankets ── -->

      <visual name="mli_top">
        <pose>0 0 0.101 0 0 0</pose>
